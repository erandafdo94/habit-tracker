---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import PostCard from "../../components/PostCard.astro";

export async function getStaticPaths({ paginate }: any) {
  const posts = (await getCollection("blog")).sort(
    (a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime(),
  );
  return paginate(posts, { pageSize: 9 });
}

const { page } = Astro.props;
const isFirst = page.currentPage === 1;
---
<Base
  title={isFirst ? "All articles, atomic" : `Articles · page ${page.currentPage}, atomic`}
  description="Every article on atomic, practical guides on building better habits and breaking the bad ones."
>
  <section class="page-header">
    <div class="container container--narrow">
      <p class="eyebrow">Articles</p>
      <h1>Every guide. All in one place.</h1>
      <p class="lede">
        Browse all {page.total} articles, or use search ({"⌘"}K) or topics to find a specific one.
      </p>
    </div>
  </section>

  <section class="listing">
    <div class="container">
      <div class="post-grid">
        {page.data.map((post: any) => <PostCard post={post} />)}
      </div>

      {(page.url.prev || page.url.next) && (
        <nav class="pager" aria-label="Pagination">
          {page.url.prev
            ? <a href={page.url.prev} class="pager-link">← Newer</a>
            : <span />}
          <span class="pager-info">Page {page.currentPage} of {page.lastPage}</span>
          {page.url.next
            ? <a href={page.url.next} class="pager-link">Older →</a>
            : <span />}
        </nav>
      )}
    </div>
  </section>
</Base>

<style>
  .page-header {
    padding: var(--space-7) 0 var(--space-6);
  }
  @media (min-width: 768px) {
    .page-header { padding: var(--space-8) 0 var(--space-7); }
  }
  .eyebrow {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: var(--space-3);
  }
  h1 {
    font-family: var(--font-serif);
    font-size: var(--step-4);
    font-weight: 500;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-4);
    max-width: 18ch;
  }
  .lede {
    font-size: var(--step-0);
    color: var(--fg-muted);
    max-width: 52ch;
  }
  .listing { padding-bottom: var(--space-9); }
  .post-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
  }
  @media (min-width: 640px) {
    .post-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (min-width: 1024px) {
    .post-grid { grid-template-columns: 1fr 1fr 1fr; }
  }
  .pager {
    margin-top: var(--space-7);
    padding-top: var(--space-5);
    border-top: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-3);
    font-size: var(--step--1);
    color: var(--fg-muted);
  }
  .pager-link {
    color: var(--fg);
    font-weight: 500;
    transition: color var(--duration-fast) var(--ease-out);
  }
  .pager-link:hover { color: var(--accent); }
</style>
