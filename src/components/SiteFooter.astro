---
import { TAGS } from "../lib/tags.ts";
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <a href="/" class="brand">
        <span class="brand-mark" aria-hidden="true">a</span>
        <span>atomic</span>
      </a>
      <p class="tagline">A blog about building better habits and breaking bad ones, without the fluff.</p>
    </div>

    <div class="footer-col">
      <h2 class="footer-heading">Topics</h2>
      <ul>
        {TAGS.map((t) => (
          <li><a href={`/tags/${t.slug}/`}>{t.label}</a></li>
        ))}
      </ul>
    </div>

    <div class="footer-col">
      <h2 class="footer-heading">Read</h2>
      <ul>
        <li><a href="/blog/">All articles</a></li>
        <li><a href="/tags/">All topics</a></li>
        <li><a href="/about/">About</a></li>
      </ul>
    </div>
  </div>

  <div class="container footer-bottom">
    <span>© {year} atomichabittracker.com</span>
    <span>Built with care.</span>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: var(--space-9);
    padding: var(--space-8) 0 var(--space-6);
    border-top: 1px solid var(--border);
    background: var(--bg-elev);
    color: var(--fg-muted);
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-7);
    margin-bottom: var(--space-7);
  }
  @media (min-width: 640px) {
    .footer-grid {
      grid-template-columns: 1.4fr 1fr 1fr;
    }
  }
  .footer-brand .brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-serif);
    font-size: var(--step-1);
    color: var(--fg);
    margin-bottom: var(--space-3);
  }
  .brand-mark {
    display: inline-grid;
    place-items: center;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--accent);
    color: white;
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: 16px;
    line-height: 1;
  }
  .tagline {
    max-width: 36ch;
    font-size: var(--step--1);
    line-height: 1.6;
  }
  .footer-heading {
    font-family: var(--font-sans);
    font-size: var(--step--1);
    font-weight: 600;
    color: var(--fg);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--space-3);
  }
  .footer-col ul {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .footer-col a {
    font-size: var(--step--1);
    color: var(--fg-muted);
    transition: color var(--duration-fast) var(--ease-out);
  }
  .footer-col a:hover { color: var(--fg); }
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-3);
    padding-top: var(--space-5);
    border-top: 1px solid var(--border);
    font-size: var(--step--1);
  }
</style>
