---
export interface Props {
  title: string;
  description: string;
  pubDate: string;
  slug: string;
}
const { title, description, pubDate, slug } = Astro.props;
const NOTION_URL = "https://atomichabit.gumroad.com/l/bnefjrs";
---
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Atomic Habit Tracker</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={`https://atomichabittracker.com/blog/${slug}`} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="article" />
    <meta property="og:url" content={`https://atomichabittracker.com/blog/${slug}`} />
    <meta name="twitter:card" content="summary" />
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-J228Q6322S"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-J228Q6322S');
    </script>
  </head>
  <body>
    <div class="site">
      <header class="site-header">
        <a href="/" class="site-logo">atomichabittracker</a>
      </header>
      <article class="post" data-pagefind-body>
        <header class="post-header">
          <p class="post-date">{pubDate}</p>
          <h1>{title}</h1>
          <p class="post-desc">{description}</p>
        </header>
        <hr />
        <div class="post-body">
          <slot />
          <aside class="post-cta" data-pagefind-ignore>
            <p><strong>Want the system, not just the theory?</strong></p>
            <p>Get the <a href={NOTION_URL} target="_blank" rel="noopener">Atomic Habits Notion template</a> — the exact setup I use to run the system daily.</p>
          </aside>
        </div>
      </article>
      <footer class="site-footer">
        <a href="/blog">← all posts</a>
        <span>© {new Date().getFullYear()} atomichabittracker.com</span>
      </footer>
    </div>
  </body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; }

  :root {
    --bg: #111;
    --bg-card: #181818;
    --border: #222;
    --text: #e8e8e8;
    --muted: #666;
    --max: 680px;
  }

  html, body {
    margin: 0;
    padding: 0;
    background: var(--bg);
    color: var(--text);
    font-family: ui-monospace, "SF Mono", "Cascadia Mono", monospace;
    font-size: 15px;
    line-height: 1.7;
    -webkit-font-smoothing: antialiased;
  }

  a { color: var(--text); text-decoration: underline; text-underline-offset: 3px; }
  a:hover { color: #fff; }
  h1, h2, h3, h4 { margin: 1.4em 0 0.4em; line-height: 1.3; font-weight: 600; }
  h1 { margin-top: 0; font-size: 22px; }
  h2 { font-size: 17px; }
  h3 { font-size: 15px; }
  p { margin: 0 0 1.2em; }
  ul, ol { padding-left: 1.4em; margin: 0 0 1.2em; }
  li { margin-bottom: 0.4em; }
  hr { border: none; border-top: 1px solid var(--border); margin: 2em 0; }
  blockquote { border-left: 2px solid var(--border); margin: 1.5em 0; padding: 0.2em 1em; color: var(--muted); }
  code { font-family: inherit; background: var(--bg-card); padding: 1px 5px; font-size: 0.9em; }

  .site {
    max-width: var(--max);
    margin: 0 auto;
    padding: 40px 24px 80px;
  }

  .site-header {
    margin-bottom: 48px;
  }

  .site-logo {
    font-size: 13px;
    font-weight: 600;
    text-decoration: none;
    letter-spacing: 0.04em;
    color: var(--text);
  }

  .post-header { margin-bottom: 0; }

  .post-date {
    font-size: 12px;
    color: var(--muted);
    margin-bottom: 8px;
  }

  .post-desc {
    color: var(--muted);
    font-size: 14px;
    margin-top: 8px;
  }

  .post-body h2 { margin-top: 2em; }

  .post-cta {
    border-left: 2px solid var(--text);
    margin: 2.5em 0 0;
    padding: 0.4em 1em;
  }
  .post-cta p { margin-bottom: 0.4em; }
  .post-cta p:last-child { margin-bottom: 0; }

  .site-footer {
    margin-top: 64px;
    font-size: 12px;
    color: var(--muted);
    border-top: 1px solid var(--border);
    padding-top: 24px;
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 8px;
  }
</style>
