---
import type { CollectionEntry } from "astro:content";
import Base from "./Base.astro";
import PostMeta from "../components/PostMeta.astro";
import RelatedPosts from "../components/RelatedPosts.astro";

export interface Props {
  post: CollectionEntry<"blog">;
  allPosts: CollectionEntry<"blog">[];
  readingMinutes: number;
}

const { post, allPosts, readingMinutes } = Astro.props;
const { title, description, pubDate, updatedDate, slug, tags } = post.data;
const primaryTag = tags[0];

const url = `https://atomichabittracker.com/blog/${slug}/`;

const articleLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title,
  description,
  datePublished: pubDate,
  ...(updatedDate ? { dateModified: updatedDate } : { dateModified: pubDate }),
  mainEntityOfPage: { "@type": "WebPage", "@id": url },
  url,
  author: { "@type": "Organization", name: "atomic", url: "https://atomichabittracker.com/" },
  publisher: { "@type": "Organization", name: "atomic" },
  keywords: tags.join(", "),
};

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: "https://atomichabittracker.com/" },
    { "@type": "ListItem", position: 2, name: "Articles", item: "https://atomichabittracker.com/blog/" },
    { "@type": "ListItem", position: 3, name: title, item: url },
  ],
};
---
<Base
  title={`${title}, atomic`}
  description={description}
  slug={slug}
  pageType="article"
  jsonLd={[articleLd, breadcrumbLd]}
>
  <article class="post" data-pagefind-body>
    <header class="post-header container container--narrow">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">/</span>
        <a href="/blog/">Articles</a>
      </nav>
      <h1>{title}</h1>
      <p class="post-deck">{description}</p>
      <div class="post-meta-row">
        <PostMeta
          pubDate={pubDate}
          updatedDate={updatedDate}
          readingMinutes={readingMinutes}
          primaryTag={primaryTag}
        />
      </div>
    </header>

    <div class="container container--narrow">
      <div class="prose post-body">
        <slot />
      </div>
    </div>
  </article>

  <RelatedPosts post={post} all={allPosts} />
</Base>

<style>
  .post {
    padding-top: var(--space-7);
  }
  @media (min-width: 768px) {
    .post {
      padding-top: var(--space-8);
    }
  }
  .post-header {
    margin-bottom: var(--space-7);
  }
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--step--1);
    color: var(--fg-muted);
    margin-bottom: var(--space-5);
  }
  .breadcrumb a {
    color: var(--fg-muted);
    transition: color var(--duration-fast) var(--ease-out);
  }
  .breadcrumb a:hover { color: var(--accent); }
  .breadcrumb span { color: var(--fg-subtle); }

  .post-header h1 {
    font-family: var(--font-serif);
    font-size: var(--step-4);
    font-weight: 500;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--fg);
    margin-bottom: var(--space-4);
    max-width: 22ch;
  }
  @media (min-width: 768px) {
    .post-header h1 {
      font-size: var(--step-5);
    }
  }
  .post-deck {
    font-family: var(--font-serif);
    font-size: var(--step-1);
    font-style: italic;
    color: var(--fg-muted);
    line-height: 1.5;
    max-width: 52ch;
    margin-bottom: var(--space-5);
  }
  .post-meta-row {
    padding-top: var(--space-4);
    border-top: 1px solid var(--border);
  }
  .post-body {
    padding-bottom: var(--space-6);
  }
</style>
